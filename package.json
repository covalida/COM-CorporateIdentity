{
  "name": "@covalida/brand-guide",
  "version": "0.2.0",
  "description": "COVALIDA Brand Guide & Corporate Identity Manual",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "setup": "npm install",
    "update": "npm update",
    "outdated": "npm outdated",
    "audit": "npm audit",
    "generate:assets": "node scripts/generate-assets.mjs",
    "predocs:dev": "npm run generate:assets",
    "docs:dev": "vitepress dev docs",
    "predocs:build": "npm run generate:assets",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:clean": "rimraf docs/.vitepress/dist docs/.vitepress/cache node_modules/.vitepress",
    "docs:serve": "vitepress serve docs --port 4173",
    "lint": "markdownlint-cli2 \"docs/**/*.md\"",
    "lint:fix": "markdownlint-cli2 --fix \"docs/**/*.md\"",
    "check:links": "linkinator docs/.vitepress/dist --recurse --skip \"^(?!http://localhost)\"",
    "validate": "npm run lint && npm run docs:build && npm run check:links",
    "ci": "npm ci && npm run lint && npm run docs:build"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.5"
  },
  "devDependencies": {
    "linkinator": "^7.6.1",
    "markdownlint-cli2": "^0.23.0",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.3",
    "vitepress": "^1.6.4"
  }
}
